 space-y-3","children":[["$","p",null,{"children":"If you are a California resident, you have the following rights under the California Consumer Privacy Act:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Right to know"}]," — you can request information about the personal data we collect and how we use it."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to delete"}]," — you can request that we delete your personal data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to opt out of sale"}]," — we do not sell your personal data to third parties."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to non-discrimination"}]," — we will not treat you differently for exercising any of these rights."]}]]}],["$","p",null,{"children":["To exercise any of these rights, contact us at"," ",["$","a",null,{"href":"mailto:appstridemind@gmail.com","className":"text-brand-dark hover:text-brand underline","children":"appstridemind@gmail.com"}],"."]}]]}]]}],["$","section",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-xl font-bold text-gray-900 pb-3 mb-4 border-b border-gray-200","children":"EEA and UK Residents (GDPR / UK GDPR)"}],["$","div",null,{"className":"text-gray-700 leading-relaxed text-lg space-y-3","children":[["$","p",null,{"children":"If you are located in the European Economic Area or the United Kingdom, you have the following rights under the General Data Protection Regulation (GDPR) or equivalent UK law:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Right of access"}]," — you can request a copy of the personal data we hold about you."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to rectification"}]," — you can ask us to correct inaccurate or incomplete data."]}],["$","li",null,{"children":[["$","s